<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="120dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="800dp"
                android:layout_height="800dp"
                android:layout_marginStart="-200dp"
                android:layout_marginTop="-500dp"
                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                app:cardCornerRadius="400dp"
                app:cardElevation="0dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:id="@+id/tvHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="64dp"
                android:fontFamily="sans-serif-black"
                android:text=""
                android:textColor="?attr/colorOnPrimaryContainer"
                android:textSize="44sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRx"
                android:layout_width="160dp"
                android:layout_height="200dp"
                android:layout_marginStart="32dp"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="?attr/colorTertiaryContainer"
                app:cardCornerRadius="32dp"
                app:cardElevation="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvHeader">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/icRx"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_nav_medicine"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="?attr/colorOnTertiaryContainer"/>

                    <TextView
                        android:id="@+id/tvRxName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text=""
                        android:textColor="?attr/colorOnTertiaryContainer"
                        android:textSize="18sp"
                        app:layout_constraintBottom_toTopOf="@+id/tvRxDesc"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:id="@+id/tvRxDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="?attr/colorOnTertiaryContainer"
                        android:textSize="14sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLab"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginTop="72dp"
                android:layout_marginEnd="32dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:cardCornerRadius="32dp"
                app:cardElevation="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvHeader">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/icLab"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/record"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="?attr/colorPrimary"/>

                    <TextView
                        android:id="@+id/tvLabTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text=""
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="18sp"
                        app:layout_constraintBottom_toTopOf="@+id/tvLabDesc"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:id="@+id/tvLabDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="14sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvTimelineHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginTop="48dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:text="HISTORY TIMELINE"
                android:textColor="?attr/colorPrimary"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardRx"/>

            <View
                android:id="@+id/timelineLine"
                android:layout_width="2dp"
                android:layout_height="0dp"
                android:layout_marginStart="41dp"
                android:layout_marginTop="24dp"
                android:background="?attr/colorOutlineVariant"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTimelineHeader"/>

            <View
                android:id="@+id/dot1"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/record"
                android:backgroundTint="?attr/colorPrimary"
                app:layout_constraintEnd_toEndOf="@id/timelineLine"
                app:layout_constraintStart_toStartOf="@id/timelineLine"
                app:layout_constraintTop_toTopOf="@id/timelineLine"/>

            <TextView
                android:id="@+id/date1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:fontFamily="sans-serif-black"
                android:text=""
                android:textColor="?attr/colorPrimary"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="@id/dot1"
                app:layout_constraintStart_toEndOf="@id/dot1"
                app:layout_constraintTop_toTopOf="@id/dot1"/>

            <TextView
                android:id="@+id/title1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="32dp"
                android:fontFamily="sans-serif-medium"
                android:text=""
                android:textColor="?attr/colorOnSurface"
                android:textSize="22sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/date1"
                app:layout_constraintTop_toBottomOf="@id/date1"/>

            <TextView
                android:id="@+id/desc1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="32dp"
                android:lineSpacingExtra="4dp"
                android:text=""
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="15sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/date1"
                app:layout_constraintTop_toBottomOf="@id/title1"/>

            <View
                android:id="@+id/dot2"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="48dp"
                android:background="@drawable/record"
                android:backgroundTint="?attr/colorOutline"
                app:layout_constraintEnd_toEndOf="@id/timelineLine"
                app:layout_constraintStart_toStartOf="@id/timelineLine"
                app:layout_constraintTop_toBottomOf="@id/desc1"/>

            <TextView
                android:id="@+id/date2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:fontFamily="sans-serif-black"
                android:text=""
                android:textColor="?attr/colorOutline"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="@id/dot2"
                app:layout_constraintStart_toEndOf="@id/dot2"
                app:layout_constraintTop_toTopOf="@id/dot2"/>

            <TextView
                android:id="@+id/title2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="32dp"
                android:fontFamily="sans-serif-medium"
                android:text=""
                android:textColor="?attr/colorOnSurface"
                android:textSize="22sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/date2"
                app:layout_constraintTop_toBottomOf="@id/date2"/>

            <TextView
                android:id="@+id/desc2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="32dp"
                android:lineSpacingExtra="4dp"
                android:text=""
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="15sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/date2"
                app:layout_constraintTop_toBottomOf="@id/title2"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabConsult"
        android:layout_width="wrap_content"
        android:layout_height="72dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:fontFamily="sans-serif-medium"
        android:text="Start Consultation"
        android:textColor="?attr/colorOnPrimary"
        android:textSize="18sp"
        app:backgroundTint="?attr/colorPrimary"
        app:elevation="8dp"
        app:icon="@drawable/stethoscope"
        app:iconSize="28dp"
        app:iconTint="?attr/colorOnPrimary"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>